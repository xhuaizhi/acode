#include <winver.h>

/* Application Icon */
IDI_APPICON ICON "app.ico"

/* Version Information */
VS_VERSION_INFO VERSIONINFO
FILEVERSION    1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "ACode Team\0"
            VALUE "FileDescription",  "ACode - AI Programming Terminal\0"
            VALUE "FileVersion",      "1.0.0\0"
            VALUE "InternalName",     "ACode\0"
            VALUE "LegalCopyright",   "Copyright (C) 2025 ACode Team\0"
            VALUE "OriginalFilename", "ACode.exe\0"
            VALUE "ProductName",      "ACode\0"
            VALUE "ProductVersion",   "1.0.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

/* Application Manifest */
1 24 "app.manifest"
